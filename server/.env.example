PORT=4000
CORS_ORIGIN=http://localhost:8080
SQLITE_DB_PATH=./data/incidents.db
INCIDENTS_LIST_LIMIT=500

SYNC_AUTH_MODE=none
SYNC_AUTH_SECRET=
SYNC_API_KEY_HEADER=x-api-key

SIGNING_REQUIRED=false
SIGNING_SECRET=replace-with-strong-shared-secret
SIGNATURE_HEADER=x-signature
SIGNATURE_TIMESTAMP_HEADER=x-signature-timestamp
SIGNATURE_NONCE_HEADER=x-signature-nonce
SIGNATURE_VERSION=v1
SIGNATURE_WINDOW_MS=300000
